/**
 * Dashboard Page Logic
 * Handles dashboard display and user interactions
 */

class Dashboard {
    constructor() {
        this.data = null;
        this.init();
    }
    
    /**
     * Initialize dashboard
     */
    async init() {
        try {
            await this.loadDashboardData();
            this.renderWelcomeBanner();
            this.renderMetricCards();
            this.renderFinancialOverview();
        } catch (error) {
            console.error('Dashboard initialization error:', error);
            Utils.showToast('Failed to load dashboard', 'danger');
        }
    }
    
    /**
     * Load data from API
     */
    async loadDashboardData() {
        Utils.showLoading('metric-cards');
        
        try {
            this.data = await api.getDashboard();
        } catch (error) {
            throw error;
        }
    }
    
    /**
     * Render welcome banner
     */
    renderWelcomeBanner() {
        const banner = document.getElementById('welcome-banner');
        if (!banner || !this.data) return;
        
        const userName = this.data.user.name || 'User';
        const healthScore = this.calculateHealthScore();
        
        banner.innerHTML = `
            <div class="flex justify-between items-center">
                <div>
                    <h2 class="text-4xl font-bold text-gray-900 mb-2">
                        Welcome back, ${userName}! 👋
                    </h2>
                    <p class="text-gray-600 text-lg">
                        Your financial health score: 
                        <span class="text-green-600 font-bold">${healthScore}/100</span>
                    </p>
                </div>
                <div class="text-right">
                    <p class="text-sm text-gray-500">Last updated</p>
                    <p class="font-semibold">Just now</p>
                </div>
            </div>
        `;
        
        // Update navbar user name
        Utils.setText('user-name', userName);
    }
    
    /**
     * Render metric cards
     */
    renderMetricCards() {
        const container = document.getElementById('metric-cards');
        if (!container || !this.data) return;
        
        const summary = this.data.financial_summary;
        
        container.innerHTML = `
            <!-- Income Card -->
            <div class="bg-white rounded-2xl shadow-lg p-6 border-l-4 border-green-500 premium-card">
                <div class="flex justify-between items-start mb-4">
                    <span class="text-3xl">💰</span>
                    <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded">Active</span>
                </div>
                <p class="text-gray-500 text-sm mb-1">Monthly Income</p>
                <p class="text-3xl font-bold text-gray-900 amount-display">
                    ${Utils.formatCurrency(this.data.user.monthly_income)}
                </p>
                <p class="text-xs text-gray-400 mt-2">Net take-home</p>
            </div>
            
            <!-- Investments Card -->
            <div class="bg-white rounded-2xl shadow-lg p-6 border-l-4 border-blue-500 premium-card">
                <div class="flex justify-between items-start mb-4">
                    <span class="text-3xl">📈</span>
                    <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded">Growing</span>
                </div>
                <p class="text-gray-500 text-sm mb-1">Total Invested</p>
                <p class="text-3xl font-bold text-gray-900 amount-display">
                    ${Utils.formatCurrency(summary.total_investments)}
                </p>
                <p class="text-xs text-green-600 mt-2">↑ Estimated returns</p>
            </div>
            
            <!-- Debt Card -->
            <div class="bg-white rounded-2xl shadow-lg p-6 border-l-4 border-orange-500 premium-card">
                <div class="flex justify-between items-start mb-4">
                    <span class="text-3xl">💳</span>
                    <span class="text-xs bg-orange-100 text-orange-700 px-2 py-1 rounded">Active</span>
                </div>
                <p class="text-gray-500 text-sm mb-1">Total Debt</p>
                <p class="text-3xl font-bold text-gray-900 amount-display">
                    ${Utils.formatCurrency(summary.total_debt)}
                </p>
                <p class="text-xs text-gray-400 mt-2">
                    ${Utils.formatCurrency(summary.monthly_emi)}/month EMI
                </p>
            </div>
            
            <!-- Savings Card -->
            <div class="bg-white rounded-2xl shadow-lg p-6 border-l-4 border-purple-500 premium-card">
                <div class="flex justify-between items-start mb-4">
                    <span class="text-3xl">🎯</span>
                    <span class="text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded">On Track</span>
                </div>
                <p class="text-gray-500 text-sm mb-1">Monthly Savings</p>
                <p class="text-3xl font-bold text-gray-900 amount-display">
                    ${Utils.formatCurrency(summary.monthly_savings)}
                </p>
                <p class="text-xs text-gray-400 mt-2">
                    ${summary.savings_rate}% of income
                </p>
            </div>
        `;
    }
    
    /**
     * Render financial overview section
     */
    renderFinancialOverview() {
        const container = document.getElementById('financial-overview');
        if (!container || !this.data) return;
        
        container.innerHTML = `
            <h3 class="text-2xl font-bold mb-6">Financial Overview</h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Income Breakdown -->
                <div class="bg-gray-50 p-6 rounded-xl">
                    <h4 class="font-bold mb-4">💰 Income Breakdown</h4>
                    <div class="space-y-3">
                        <div class="flex justify-between">
                            <span class="text-gray-600">Gross Income</span>
                            <span class="font-bold">${Utils.formatCurrency(this.data.user.monthly_income * 1.2)}</span>
                        </div>
                        <div class="flex justify-between text-red-600">
                            <span>- Taxes & Deductions</span>
                            <span class="font-bold">-${Utils.formatCurrency(this.data.user.monthly_income * 0.2)}</span>
                        </div>
                        <div class="border-t-2 pt-2 flex justify-between">
                            <span class="font-bold">Net Income</span>
                            <span class="font-bold text-green-600">${Utils.formatCurrency(this.data.user.monthly_income)}</span>
                        </div>
                    </div>
                </div>
                
                <!-- Expense Distribution -->
                <div class="bg-gray-50 p-6 rounded-xl">
                    <h4 class="font-bold mb-4">📊 Expense Distribution</h4>
                    <div class="space-y-2">
                        ${this.renderExpenseDistribution()}
                    </div>
                </div>
            </div>
        `;
    }
    
    /**
     * Render expense distribution bars
     */
    renderExpenseDistribution() {
        if (!this.data) return '';
        
        const summary = this.data.financial_summary;
        const income = this.data.user.monthly_income;
        
        const categories = [
            { label: 'Expenses', amount: summary.monthly_expenses, color: 'bg-blue-500' },
            { label: 'EMI', amount: summary.monthly_emi, color: 'bg-orange-500' },
            { label: 'Savings', amount: summary.monthly_savings, color: 'bg-green-500' }
        ];
        
        return categories.map(cat => {
            const percent = ((cat.amount / income) * 100).toFixed(1);
            return `
                <div>
                    <div class="flex justify-between text-sm mb-1">
                        <span>${cat.label}</span>
                        <span>${Utils.formatCurrency(cat.amount)} (${percent}%)</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="${cat.color} h-2 rounded-full transition-all" style="width: ${percent}%"></div>
                    </div>
                </div>
            `;
        }).join('');
    }
    
    /**
     * Calculate health score (simple version)
     */
    calculateHealthScore() {
        if (!this.data) return 0;
        
        const summary = this.data.financial_summary;
        const income = this.data.user.monthly_income;
        
        // Simple scoring logic
        const savingsRate = summary.savings_rate;
        const debtRatio = (summary.monthly_emi / income) * 100;
        
        let score = 50; // Base score
        
        // Add points for good savings rate
        if (savingsRate > 20) score += 25;
        else if (savingsRate > 10) score += 15;
        else if (savingsRate > 5) score += 5;
        
        // Subtract points for high debt
        if (debtRatio > 40) score -= 20;
        else if (debtRatio > 30) score -= 10;
        
        // Add points for investments
        if (summary.total_investments > 0) score += 15;
        
        return Math.max(0, Math.min(100, score));
    }
}

// Initialize dashboard when DOM is ready
document.addEventListener('DOMContentLoaded', () => {
    new Dashboard();
});
